# Secret key from https://console.anthropic.com/settings/keys — single line, no quotes
ANTHROPIC_API_KEY=
# Optional; default 8192. Increase (e.g. 16384) if generation fails with truncated JSON.
# ANTHROPIC_MAX_TOKENS=16384
# Clarification UI only if the model returns this many follow-up questions (default 2). Set to 1 to be more sensitive.
# MIN_FOLLOW_UP_QUESTIONS=2
DATABASE_URL=sqlite:///./cases.db
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Optional (Railway demo): allow every *.vercel.app preview without listing each hash:
# ALLOWED_ORIGINS_REGEX=^https://.*\.vercel\.app$
